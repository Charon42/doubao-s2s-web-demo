# FastAPI
HOST=127.0.0.1
PORT=8000

# Doubao end-to-end realtime speech S2S WebSocket.
DOUBAO_WS_URL=wss://openspeech.bytedance.com/api/v3/realtime/dialogue

# Required handshake headers:
# X-Api-App-ID: DOUBAO_APP_ID
# X-Api-Access-Key: DOUBAO_ACCESS_KEY
# X-Api-Resource-Id: DOUBAO_RESOURCE_ID
# X-Api-App-Key: DOUBAO_APP_KEY
# X-Api-Connect-Id: generated by backend per connection
DOUBAO_APP_ID=5879808045
DOUBAO_ACCESS_KEY=EtJw5My_Tw-alu1w52rArE9wssyZTXGe
DOUBAO_RESOURCE_ID=volc.speech.dialog
DOUBAO_APP_KEY=PlgvMymc7f3tQnJ6

# Session options.
# TODO: Confirm the exact model_version field path in StartSession payload
# against the official Volcengine realtime dialogue documentation.
DOUBAO_MODEL_VERSION=1.2.1.1
DOUBAO_SPEAKER=zh_female_vv_jupiter_bigtts

# Browser sends PCM16 mono 16kHz little-endian audio.
# The backend splits it into 20ms packets, 640 bytes per packet.
DOUBAO_INPUT_SAMPLE_RATE=16000
DOUBAO_OUTPUT_SAMPLE_RATE=24000

DOUBAO_BOT_NAME=小蔚
DOUBAO_SYSTEM_ROLE=
DOUBAO_SPEAKING_STYLE=
DOUBAO_GREETING=你好，我是小蔚，今天我们聊点什么呢？
DOUBAO_INPUT_MOD=keep_alive
